rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is user signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // User profiles
    match /userProfiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role == "super_admin");
    }

    // Roles
    match /roles/{roleId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Categories
    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Items
    match /items/{itemId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Transactions
    match /transactions/{transactionId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Productions
    match /productions/{productionId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Formulas
    match /formulas/{formulaId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Settings
    match /settings/{settingsId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Audit Logs
    match /auditLogs/{logId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
